  "messages": {
    "type": "请选择你要提交的更改类型：",
    "scope": "请填写更改的影响范围 (例如：组件或文件名称) (可选)：",
    "subject": "请简明扼要地描述更改 (必填，最多 90 个字符)：",
    "body": "请提供更详细的更改说明，可以多行 (可选)：\n",
    "breaking": "列出所有的破坏性变更 (如无，请直接回车跳过) (可选)：\n",
    "issues": "列出本次更改修复或关联的 issues编号 (如：#123, #124) (可选)：\n"
  }
}
