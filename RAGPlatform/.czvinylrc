{
  "headerFormat": "{type}{scope}: {emoji} {subject}",
  "commitTypes": [
    {
      "value": "feat",
      "description": "新增功能",
      "emoji": "✨"
    },
    {
      "value": "fix",
      "description": "修复缺陷",
      "emoji": "🐛"
    },
    {
      "value": "docs",
      "description": "文档更新",
      "emoji": "📝"
    },
    {
      "value": "style",
      "description": "代码格式，不影响代码运行的变动",
      "emoji": "💄"
    },
    {
      "value": "refactor",
      "description": "代码重构，既不是新增功能，也不是修复缺陷",
      "emoji": "♻️"
    },
    {
      "value": "perf",
      "description": "性能优化",
      "emoji": "⚡️"
    },
    {
      "value": "test",
      "description": "测试相关，增加测试或修改现有测试",
      "emoji": "✅"
    },
    {
      "value": "build",
      "description": "构建相关，打包配置或依赖调整",
      "emoji": "📦️"
    },
    {
      "value": "ci",
      "description": "持续集成，CI 配置文件和脚本更改",
      "emoji": "🎡"
    },
    {
      "value": "chore",
      "description": "其他修改，不在上述类型中的杂项修改",
      "emoji": "🔨"
    },
    {
      "value": "revert",
      "description": "回滚代码",
      "emoji": "⏪️"
    }
  ],
  "typeQuestion": "请选择你要提交的更改类型：\n",
  "scopeQuestion": "请输入更改范围，例如组件或模块名：",
  "skipScope": true,
  "ticketIdQuestion": "请输入关联任务编号，如无可跳过：",
  "skipTicketId": true,
  "subjectQuestion": "请简明扼要地描述更改：\n",
  "subjectMaxLength": 90,
  "subjectMinLength": 1,
  "bodyQuestion": "请提供更详细的更改说明，可以多行：\n",
  "skipBody": true,
  "skipBreakingChanges": true,
  "issuesQuestion": "请输入关联 issue，例如 #123：",
  "skipIssues": true
}
