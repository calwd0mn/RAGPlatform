5,\n            425\n        ],\n        \"page_idx\": 3\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"GB/T37375交通运输物联网标识规则\",\n        \"bbox\": [\n            147,\n            429,\n            480,\n            443\n        ],\n        \"page_idx\": 3\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"3交通运输对象标识基础分类\",\n        \"text_level\": 2,\n        \"bbox\": [\n            114,\n            466,\n            359,\n            481\n        ],\n        \"page_idx\": 3\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"针对交通运输行业中具有管理需求的交通运输对象，结合物联网应用的特点对交通运输对象标识进行分类。交通运输对象标识基础分类代码见表1。\",\n        \"bbox\": [\n            112,\n            502,\n            897,\n            538\n        ],\n        \"page_idx\": 3\n    },\n    {\n        \"type\": \"table\",\n        \"img_path\": \"images/d8504cfd931d5873026249e2eefb3211788161769f86e4e4796c06d9e345422f.jpg\",\n        \"table_caption\": [\n            \"表1交通运输对象标识基础分类代码\"\n        ],\n        \"table_footnote\": [],\n        \"table_body\": \"<table><tr><td rowspan=1 colspan=1>基础分类代码</td><td rowspan=1 colspan=1>对象标识类别</td></tr><tr><td rowspan=1 colspan=1>01</td><td rowspan=1 colspan=1>交通运输从业人员</td></tr><tr><td rowspan=1 colspan=1>02</td><td rowspan=1 colspan=1>交通运载工具</td></tr><tr><td rowspan=1 colspan=1>03</td><td rowspan=1 colspan=1>交通基础设施</td></tr><tr><td rowspan=1 colspan=1>04</td><td rowspan=1 colspan=1>车载、船载设备</td></tr><tr><td rowspan=1 colspan=1>05</td><td rowspan=1 colspan=1>路侧、岸侧交通机电节点设备</td></tr><tr><td rowspan=1 colspan=1>99</td><td rowspan=1 colspan=1>其他</td></tr></table>\",\n        \"bbox\": [\n            115,\n            577,\n            894,\n            728\n        ],\n        \"page_idx\": 3\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"4交通运输从业人员对象标识分类及编码\",\n        \"text_level\": 2,\n        \"bbox\": [\n            114,\n            764,\n            447,\n            778\n        ],\n        \"page_idx\": 3\n    },\n  