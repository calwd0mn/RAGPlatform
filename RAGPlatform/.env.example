# =========================
# Frontend (root/.env.development)
# =========================
VITE_API_BASE_URL=/api
# 若后端设置了 RAG_DEBUG_ACCESS_TOKEN，可在前端调试页配置同值
VITE_DEBUG_ACCESS_TOKEN=
# 仅开发联调可用，生产建议 false
VITE_DEV_BYPASS_AUTH=false

# =========================
# Backend (nest-service/.env)
# =========================
PORT=3000
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN_SECONDS=604800
MONGODB_URI=mongodb://127.0.0.1:27017/rag-platform

# Retrieval / RAG
RAG_RETRIEVAL_PROVIDER=local
RAG_TOP_K_DEFAULT=10
RAG_VECTOR_INDEX_NAME=chunk_vector_index
RAG_VECTOR_PATH=embedding
RAG_VECTOR_CANDIDATE_LIMIT=100
RAG_RETRIEVAL_ALLOW_FALLBACK_TO_LOCAL=false

# Chat model
RAG_CHAT_PROVIDER=openai
RAG_CHAT_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Ingestion embeddings
INGESTION_EMBEDDINGS_PROVIDER=deterministic
INGESTION_EMBEDDINGS_MODEL=text-embedding-3-small
INGESTION_EMBEDDINGS_BATCH_SIZE=10

# Debug access control
RAG_DEBUG_ENABLED=true
RAG_DEBUG_ACCESS_TOKEN=

# Documents
DOCUMENTS_UPLOAD_DIR=
DOCUMENT_MAX_FILE_SIZE_BYTES=20971520
