"[\n    {\n        \"type\": \"text\",\n        \"text\": \"中 华 人 民 共 和 国 国 家 标 准\",\n        \"text_level\": 1,\n        \"bbox\": [\n            87,\n            146,\n            909,\n            184\n        ],\n        \"page_idx\": 0\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"犌犅／犜21381—2008\",\n        \"bbox\": [\n            677,\n            212,\n            885,\n            231\n        ],\n        \"page_idx\": 0\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"交通管理地理信息实体标识编码规则城市道路\",\n        \"text_level\": 1,\n        \"bbox\": [\n            131,\n            395,\n            867,\n            474\n        ],\n        \"page_idx\": 0\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"犆狅犱犻狀犵狉狌犾犲狊犳狅狉犲狀狋犻狋狔犻犱犲狀狋犻犳犻犮犪狋犻狅狀犮狅犱犲狅犳狋狉犪犳犳犻犮犿犪狀犪犵犲犿犲狀狋犵犲狅犵狉犪狆犺犻犮犪犾 犻狀犳狅狉犿犪狋犻狅狀—犆犻狋狔狉狅犪犱\",\n        \"text_level\": 1,\n        \"bbox\": [\n            105,\n            502,\n            890,\n            546\n        ],\n        \"page_idx\": 0\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"20080213发布\",\n        \"bbox\": [\n            89,\n            856,\n            260,\n            875\n        ],\n        \"page_idx\": 0\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"20080801实施\",\n        \"bbox\": [\n            736,\n            856,\n            907,\n            875\n        ],\n        \"page_idx\": 0\n    },\n    {\n        \"type\": \"header\",\n        \"text\": \"犐犆犛03．220．20 犚07\",\n        \"bbox\": [\n            90,\n            43,\n            213,\n            71\n        ],\n        \"page_idx\": 0\n    },\n    {\n        \"type\": \"header\",\n        \"text\": \"GB\",\n        \"bbox\": [\n            652,\n            52,\n            850,\n            123\n        ],\n        \"page_idx\": 0\n    },\n    {\n        \"type\": \"footer\",\n        \"text\": \"中华人民共和国国家质量监督检验检疫总局中 国 国 家 标 准 化 管 理 委 员 会 发 布\",\n        \"bbox\": [\n            198,\n            897,\n            796,\n            946\n        ],\n        \"page_idx\": 0\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"前 言\",\n        \"text_level\": 2,\n        \"bbox\": [\n            443,\n            135,\n            554,\n            156\n        ],\n        \"page_idx\": 2\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"本标准的附录A为资料性附录。\",\n        \"bbox\": [\n            142,\n            195,\n            391,\n            209\n        ],\n        \"page_idx\": 2\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"本标准由全国智能运输系统标准化技术委员会（SAC／TC268）提出并归口。\",\n        \"bbox\": [\n            142,\n            212,\n            717,\n            228\n        ],\n        \"page_idx\": 2\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"本标准起草单位：北京市公安局公安交通管理局交通科研所、北京四通智能交通系统集成有限公司。\",\n        \"bbox\": [\n            107,\n            231,\n            889,\n            265\n        ],\n        \"page_idx\": 2\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"本标准主要起草人：隋亚刚、梁玉庆、孔涛、单海辉、关积珍、王义生、计燕翎、杨劲夫。\",\n        \"bbox\": [\n            141,\n            268,\n            774,\n            285\n        ],\n        \"page_idx\": 2\n    },\n    {\n        \"type\": \"header\",\n        \"text\": \"犌犅／犜21381—2008\",\n        \"bbox\": [\n            736,\n            74,\n            889,\n            87\n        ],\n        \"page_idx\": 2\n    },\n    {\n        \"type\": \"page_number\",\n        \"text\": \"Ⅰ\",\n        \"bbox\": [\n            867,\n            912,\n            878,\n            923\n        ],\n        \"page_idx\": 2\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"交通管理地理信息实体标识编码规则城市道路\",\n        \"text_level\": 1,\n        \"bbox\": [\n            285,\n            133,\n            710,\n            177\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"1 范围\",\n        \"text_level\": 2,\n        \"bbox\": [\n            109,\n            205,\n            176,\n            219\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"本标准规定了城市道路交通管理中的地理信息实体编码基本规则、编码基本结构及道路路段、交叉口、道路沿线的交通设施和重点单位等与交通控制管理密切相关的信息实体的编码规则。\",\n        \"bbox\": [\n            107,\n            233,\n            889,\n            266\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"本标准适用于全国大、中、小城市在城市交通管理过程中对道路路段、交叉口、道路沿线的交通设施和重点单位等实体的编码及进行标识、信息处理与信息交换。\",\n        \"bbox\": [\n            107,\n            268,\n            889,\n            302\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"2 规范性引用文件\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            311,\n            265,\n            326\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"下列文件中的条款通过本标准的引用而成为本标准的条款。凡是注日期的引用文件，其随后所有的修改单（不包括勘误的内容）或修订版均不适用于本标准，然而，鼓励根据本标准达成协议的各方研究是否可使用这些文件的最新版本。凡是不注日期的引用文件，其最新版本适用于本标准。\",\n        \"bbox\": [\n            107,\n            338,\n            889,\n            390\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"GB／T2260 中华人民共和国行政区划代码\",\n        \"bbox\": [\n            141,\n            391,\n            484,\n            406\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"3 术语和定义\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            417,\n            228,\n            431\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"下列术语和定义适用于本标准。\",\n        \"bbox\": [\n            144,\n            444,\n            386,\n            460\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"3．1\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            462,\n            141,\n            475\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"重点单位 犻犿狆狅狉狋犪狀狋狌狀犻狋\",\n        \"text_level\": 2,\n        \"bbox\": [\n            142,\n            479,\n            347,\n            494\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"对交通产生较大影响的单位。\",\n        \"bbox\": [\n            142,\n            497,\n            368,\n            511\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"3．2\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            514,\n            141,\n            527\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"交通设施 狋狉犪犳犳犻犮犳犪犮犻犾犻狋犻犲狊\",\n        \"text_level\": 2,\n        \"bbox\": [\n            144,\n            532,\n            354,\n            546\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"在道路上用于交通管理、控制、信息监测、违法监测和信息显示等的各种交通设备。\",\n        \"bbox\": [\n            141,\n            549,\n            764,\n            564\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"3．3\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            568,\n            141,\n            581\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"定位单元 犾狅犮犪狋犻狀犵狌狀犻狋\",\n        \"text_level\": 2,\n        \"bbox\": [\n            142,\n            585,\n            332,\n            599\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"能够表明地理空间位置的地理信息实体。\",\n        \"bbox\": [\n            144,\n            602,\n            457,\n            617\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"4 编码编制基本规则\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            629,\n            282,\n            643\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"4．1 交通管理地理信息实体标识编码采用数字和字母。\",\n        \"bbox\": [\n            107,\n            655,\n            536,\n            670\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"4．2 交通管理信息实体编码的定位单元为道路。\",\n        \"bbox\": [\n            107,\n            673,\n            484,\n            687\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"4．3 交通管理地理信息实体和其编码之间存在一一对应关系。\",\n        \"bbox\": [\n            107,\n            690,\n            588,\n            706\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5 交通管理地理信息实体标识编码规则\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            717,\n            423,\n            731\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．1 基本结构\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            744,\n            230,\n            757\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"交通管理地理信息实体标识编码由方位代码和信息实体代码组成。\",\n        \"bbox\": [\n            142,\n            760,\n            650,\n            776\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．2 方位代码\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            778,\n            230,\n            793\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．2．1 代码结构\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            796,\n            247,\n            809\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"方位代码为确定地理位置的定位单元的代码，即道路代码。\",\n        \"bbox\": [\n            142,\n            814,\n            589,\n            827\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"方位代码采用10位码，由6位行政区划代码和4位道路顺序代码组成。方位代码结构如下：\",\n        \"bbox\": [\n            142,\n            831,\n            843,\n            846\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"image\",\n        \"img_path\": \"images/09680f54bddb3c87507a5512b2a2813c0338c40645ad0788cc694f683450a6a4.jpg\",\n        \"image_caption\": [],\n        \"image_footnote\": [],\n        \"bbox\": [\n            352,\n            848,\n            645,\n            907\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"header\",\n        \"text\": \"犌犅／犜21381—2008\",\n        \"bbox\": [\n            736,\n            74,\n            889,\n            87\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"page_number\",\n        \"text\": \"1\",\n        \"bbox\": [\n            865,\n            912,\n            877,\n            923\n        ],\n        \"page_idx\": 4\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．2．2 行政区划代码\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            107,\n            282,\n            121\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"行政区划代码按 GB／T2260表示。\",\n        \"bbox\": [\n            142,\n            124,\n            411,\n            139\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．2．3 道路顺序代码\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            142,\n            282,\n            156\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．2．3．1 在本行政区内的道路顺序代码采用4位数字表示，按照起点由东向西和由南向北的顺序编号。新修建道路的顺序代码在本行政区内的道路序号之后依次增加。\",\n        \"bbox\": [\n            107,\n            160,\n            889,\n            193\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．2．3．2 跨越多个行政区的道路的特殊道路，顺序代码采用1位字母和3位数字组合表示，第一位代码采用字母，不同行政区的同一条道路的顺序代号惟一，且其所在的相同级别的行政区代码用“0”表示，编码示例参见表A．1。\",\n        \"bbox\": [\n            107,\n            196,\n            890,\n            247\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3 信息实体代码\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            250,\n            265,\n            265\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．1 信息实体分类\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            268,\n            282,\n            282\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"城市交通管理地理信息实体包括：路段、道路交叉口、交通设施和重点单位等。\",\n        \"bbox\": [\n            141,\n            286,\n            729,\n            302\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．2 路段代码\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            305,\n            247,\n            318\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．2．1 代码结构\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            323,\n            265,\n            337\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"路段代码采用13位码，由方位代码和路段顺序代码组成。编码示例参见表 A．2。\",\n        \"bbox\": [\n            141,\n            340,\n            756,\n            355\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．2．2 路段顺序代码\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            359,\n            299,\n            373\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"路段顺序代码采用3位数字码，按同一条道路由起点至终点的路段顺序编码。\",\n        \"bbox\": [\n            141,\n            376,\n            729,\n            392\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．3 道路交叉口代码\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            395,\n            299,\n            409\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．3．1 代码结构\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            413,\n            265,\n            426\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"道路交叉口代码采用13位码，由方位代码和交叉口顺序代码组成。编码示例参见表 A．3。\",\n        \"bbox\": [\n            141,\n            430,\n            826,\n            445\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．3．2 道路交叉口顺序代码\",\n        \"text_level\": 2,\n        \"bbox\": [\n            107,\n            449,\n            352,\n            462\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．3．2．1 道路交叉口顺序代码采用3位数字码，按同一条道路由起点至终点的交叉口顺序编号。\",\n        \"bbox\": [\n            107,\n            466,\n            863,\n            481\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．3．2．2 道路交叉口所属方位代码依方位代码的排序进行判定，排序在前的方位代码为道路交叉口所属的方位代码。\",\n        \"bbox\": [\n            107,\n            485,\n            887,\n            517\n        ],\n        \"page_idx\": 5\n    },\n    {\n        \"type\": \"text\",\n        \"text\": \"5．3．